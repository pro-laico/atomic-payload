{
  "name": "@pro-laico/images",
  "version": "0.4.0",
  "description": "Atomic Payload images package. Provides Images + Favicons Payload upload collections, on-demand Sharp transforms with built-in LQIP blur placeholders, a FaviconField helper, an ImageChild block factory, and a plugin factory.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pro-laico/atomic-payload.git",
    "directory": "packages/images"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/types/payload-augment.d.ts",
        "default": "./dist/types/payload-augment.js"
      },
      "./cache": {
        "types": "./dist/cache/index.d.ts",
        "default": "./dist/cache/index.js"
      },
      "./blocks/imageChild": {
        "types": "./dist/blocks/imageChild/block.d.ts",
        "default": "./dist/blocks/imageChild/block.js"
      },
      "./blocks/imageChild/component": {
        "types": "./dist/blocks/imageChild/component.d.ts",
        "default": "./dist/blocks/imageChild/component.js"
      },
      "./components/image": {
        "types": "./dist/components/image.d.ts",
        "default": "./dist/components/image.js"
      },
      "./components/buildSrcset": {
        "types": "./dist/components/buildSrcset.d.ts",
        "default": "./dist/components/buildSrcset.js"
      },
      "./endpoints/transform": {
        "types": "./dist/endpoints/transform.d.ts",
        "default": "./dist/endpoints/transform.js"
      },
      "./admin/focalPreview": {
        "types": "./dist/components/admin/focalPreview.d.ts",
        "default": "./dist/components/admin/focalPreview.js"
      },
      "./admin/purgeVariants": {
        "types": "./dist/components/admin/purgeVariants.d.ts",
        "default": "./dist/components/admin/purgeVariants.js"
      }
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/types/payload-augment.ts",
      "default": "./src/types/payload-augment.ts"
    },
    "./cache": {
      "types": "./src/cache/index.ts",
      "default": "./src/cache/index.ts"
    },
    "./blocks/imageChild": {
      "types": "./src/blocks/imageChild/block.ts",
      "default": "./src/blocks/imageChild/block.ts"
    },
    "./blocks/imageChild/component": {
      "types": "./src/blocks/imageChild/component.tsx",
      "default": "./src/blocks/imageChild/component.tsx"
    },
    "./components/image": {
      "types": "./src/components/image.tsx",
      "default": "./src/components/image.tsx"
    },
    "./components/buildSrcset": {
      "types": "./src/components/buildSrcset.ts",
      "default": "./src/components/buildSrcset.ts"
    },
    "./endpoints/transform": {
      "types": "./src/endpoints/transform.ts",
      "default": "./src/endpoints/transform.ts"
    },
    "./admin/focalPreview": {
      "types": "./src/components/admin/focalPreview.tsx",
      "default": "./src/components/admin/focalPreview.tsx"
    },
    "./admin/purgeVariants": {
      "types": "./src/components/admin/purgeVariants.tsx",
      "default": "./src/components/admin/purgeVariants.tsx"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm copyfiles && pnpm build:types && pnpm build:swc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:swc": "swc ./src -d ./dist --config-file ../../.swcrc --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --noCheck",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{scss,css,svg,json,ttf,woff,woff2,eot}\" dist/"
  },
  "dependencies": {
    "@pro-laico/core": "workspace:*"
  },
  "peerDependencies": {
    "@payloadcms/ui": ">=3.0.0",
    "@pro-laico/atomic": ">=0.4.0",
    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0",
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "@pro-laico/atomic": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@payloadcms/ui": "^3.85.0",
    "@pro-laico/atomic": "workspace:*",
    "@tools/test-helpers": "workspace:*",
    "@types/react": "^19.2.17",
    "next": "^16.2.7",
    "payload": "^3.85.0",
    "react": "^19.2.7",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}

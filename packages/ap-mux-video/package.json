{
  "name": "@pro-laico/ap-mux-video",
  "version": "0.1.0",
  "description": "Atomic Payload mux-video plugin. Thin wrapper around @oversightstudio/mux-video that adds a local MuxVideo extension collection with Atomic Payload defaults.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./blocks/videoChild": {
      "types": "./src/blocks/videoChild/block.ts",
      "default": "./src/blocks/videoChild/block.ts"
    },
    "./blocks/videoChild/component": {
      "types": "./src/blocks/videoChild/component.tsx",
      "default": "./src/blocks/videoChild/component.tsx"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm clean && pnpm build",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pro-laico/ap-core": "workspace:*",
    "@pro-laico/children": "workspace:*",
    "@mux/mux-video-react": "^0.25.3"
  },
  "peerDependencies": {
    "@oversightstudio/mux-video": ">=1.0.0",
    "payload": ">=3.0.0"
  },
  "devDependencies": {
    "@oversightstudio/mux-video": "^1.4.0",
    "payload": "^3.79.0",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

PAYLOAD_SECRET=replace-me-with-a-long-random-string
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional. Defaults to `file:./font-only.db` (local SQLite). Swap to any
# Payload-supported adapter by editing src/payload.config.ts and setting the
# matching connection string here.
# DATABASE_URI=file:./font-only.db

# Downloading fonts for next/font/local (`pnpm generate:fonts`) authenticates
# with PAYLOAD_SECRET (above) and fetches from FONT_DOWNLOAD_URL — the running
# Payload instance to pull the active fonts from. For local dev, `pnpm setup:fonts`
# boots a temporary server and points this at it for you.
FONT_DOWNLOAD_URL=http://localhost:3000

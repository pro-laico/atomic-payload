# Analytics for the docs site. All optional — each provider is enabled only when
# its variables are set, so by default no analytics run. Copy to `.env.local`.

# PostHog — project API key + host (e.g. https://us.i.posthog.com).
# Enabled when BOTH are set.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Google Tag Manager container id (e.g. GTM-XXXXXXX). Enabled when set.
NEXT_PUBLIC_GTM_ID=

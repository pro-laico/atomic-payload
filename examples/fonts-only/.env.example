PAYLOAD_SECRET=replace-me-with-a-long-random-string
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional. Defaults to `file:./font-only.db` (local SQLite). Swap to any
# Payload-supported adapter by editing src/payload.config.ts and setting the
# matching connection string here.
# DATABASE_URI=file:./font-only.db

# Used to download the active fonts for next/font/local. For local dev,
# `pnpm setup:fonts` boots a temporary server and sets LIVE_SITE_URL for you —
# you only need the SCRIPT_USER_* credentials below (the admin user you created).
# To run `generate:fonts` directly (e.g. in CI / prebuild), point LIVE_SITE_URL
# at a reachable Payload instance (a running dev server or a deploy) instead.
# LIVE_SITE_URL=http://localhost:3000
# SCRIPT_USER_EMAIL=admin@example.com
# SCRIPT_USER_PASSWORD=your-password

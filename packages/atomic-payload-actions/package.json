{
  "name": "@pro-laico/atomic-payload-actions",
  "version": "0.1.0",
  "description": "Atomic Payload action blocks, shared action fields, and Payload plugin. Ships TypeScript source; the app transpiles it.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./fields": {
      "types": "./src/fields/index.ts",
      "default": "./src/fields/index.ts"
    },
    "./fields/keyText": {
      "types": "./src/fields/keyText.ts",
      "default": "./src/fields/keyText.ts"
    },
    "./fields/strict/registry/theme": {
      "types": "./src/fields/strict/registry/theme.ts",
      "default": "./src/fields/strict/registry/theme.ts"
    },
    "./fields/strict/registry/cookieConsent": {
      "types": "./src/fields/strict/registry/cookieConsent.ts",
      "default": "./src/fields/strict/registry/cookieConsent.ts"
    },
    "./zap": {
      "types": "./src/blocks/zap.ts",
      "default": "./src/blocks/zap.ts"
    },
    "./blocks": {
      "types": "./src/blocks/blocks.ts",
      "default": "./src/blocks/blocks.ts"
    },
    "./processor": {
      "types": "./src/blocks/processor.ts",
      "default": "./src/blocks/processor.ts"
    },
    "./filters": {
      "types": "./src/blocks/filters.ts",
      "default": "./src/blocks/filters.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm clean && pnpm build",
    "lint": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@pro-laico/atomic-payload-apf": "workspace:*",
    "@pro-laico/atomic-payload-types": "workspace:*",
    "@pro-laico/atomic-payload-zap": "workspace:*"
  },
  "peerDependencies": {
    "payload": ">=3.0.0"
  },
  "devDependencies": {
    "payload": "^3.79.0",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

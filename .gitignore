node_modules
.next
.vercel
.DS_Store

# SQLite databases (Payload local SQLite adapter — created at runtime, never committed)
*.db
*.db-journal
*.db-wal
*.db-shm

public/robots.txt
public/sitemap*.xml

.env
.env*.local

# Output of 'npm pack'
*.tgz

# Ignore all automatically generated font files
templates/atomic-payload/public/fonts

# Generated by `generate:icons` — the icon-usage manifest the admin panel reads
templates/atomic-payload/icon-usage-manifest.json

# icons-only seed assets are populated locally by the seed script
examples/icons-only/icon/

# icons-only: generated by `generate:icons` — the icon-usage manifest the admin panel reads
examples/icons-only/icon-usage-manifest.json

# fonts-only stores uploaded font files here at runtime
examples/fonts-only/media/

# fonts-only: generated by `generate:fonts` for next/font/local
examples/fonts-only/public/fonts/


# Built package output — generated on prepack, published via publishConfig (src→dist swap).
# Dev consumes src directly via turbopack, so dist is never needed in git.
packages/*/dist

# CLI bundled scaffolds (generated during prepack)
packages/create-atomic-payload/scaffolds

# Keep local Claude config out of the repo, but track shared project skills.
.claude/*
!.claude/skills/

# Logs
*.log
npm-debug.log*
.pnpm-debug.log*

# Build / tooling caches
.swc
.turbo
*.tsbuildinfo

# Next.js static export
out/

# Next.js generated type shim — regenerated by `next dev`/`next build`. The
# dev/build variants differ (.next/dev/types vs .next/types), so committing it
# would churn on every build (e.g. during `pnpm test`).
next-env.d.ts

# Editors
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Windows OS files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
{
  "name": "fonts-only",
  "version": "0.3.4",
  "description": "Minimal Atomic Payload template demonstrating @pro-laico/fonts in isolation — upload fonts to the Font collection, pick the active set, and serve them with next/font/local.",
  "license": "MIT",
  "type": "module",
  "exports": {},
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prebuild": "pnpm generate:fonts",
    "generate:fonts": "pnpm exec tsx node_modules/@pro-laico/fonts/src/scripts/cli.ts",
    "setup:fonts": "cross-env FONT_DOWNLOAD_URL=http://localhost:3000 start-server-and-test dev http://localhost:3000 generate:fonts",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "payload": "payload",
    "generate:types": "cross-env NODE_OPTIONS=\"--conditions=react-server\" payload generate:types && core-augment-types",
    "generate:importmap": "cross-env NODE_OPTIONS=\"--conditions=react-server\" payload generate:importmap"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "^3.85.0",
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/sdk": "^3.85.0",
    "@payloadcms/ui": "^3.85.0",
    "@pro-laico/core": "workspace:*",
    "@pro-laico/fonts": "workspace:*",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.7",
    "payload": "^3.85.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "start-server-and-test": "^3.0.8",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "24.x"
  }
}

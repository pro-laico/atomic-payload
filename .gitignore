node_modules
.next
.vercel
.DS_Store

# TypeScript
tsconfig.tsbuildinfo

# SQLite databases (Payload local SQLite adapter — created at runtime, never committed)
*.db
*.db-journal
*.db-wal
*.db-shm

public/robots.txt
public/sitemap*.xml

.env
.env*.local

# Output of 'npm pack'
*.tgz

# Ignore all automatically generated font files
templates/atomic-payload/src/app/definition.ts
templates/atomic-payload/public/fonts

# icons-only seed assets are populated locally by the seed script
templates/icons-only/icon/

# fonts-only stores uploaded font files here at runtime
templates/fonts-only/media/

# fonts-only: binaries downloaded by `download:fonts` for next/font/local
# (the definition.ts stub it overwrites stays committed)
templates/fonts-only/public/fonts/


# CLI packed template (generated during prepack)
packages/create-atomic-payload/template

.claude
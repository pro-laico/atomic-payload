{
  "name": "@pro-laico/images",
  "version": "0.1.0",
  "description": "Atomic Payload images package. Provides Images + Favicons Payload upload collections, a FaviconField helper, and a plugin factory that optionally wires the @oversightstudio/blur-data-urls plugin.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/types/payload-augment.ts",
      "default": "./src/types/payload-augment.ts"
    },
    "./blocks/imageChild": {
      "types": "./src/blocks/imageChild/block.ts",
      "default": "./src/blocks/imageChild/block.ts"
    },
    "./blocks/imageChild/component": {
      "types": "./src/blocks/imageChild/component.tsx",
      "default": "./src/blocks/imageChild/component.tsx"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm clean && pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pro-laico/core": "workspace:*",
    "@pro-laico/atomic": "workspace:*"
  },
  "peerDependencies": {
    "@oversightstudio/blur-data-urls": ">=1.0.0",
    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "@oversightstudio/blur-data-urls": {
      "optional": true
    }
  },
  "devDependencies": {
    "@oversightstudio/blur-data-urls": "^1.0.4",
    "@types/react": "^19.2.14",
    "next": "^16.1.6",
    "payload": "^3.79.0",
    "react": "^19.2.4",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

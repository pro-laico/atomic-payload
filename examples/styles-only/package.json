{
  "name": "styles-only",
  "version": "0.4.2",
  "description": "Minimal Atomic Payload template demonstrating @pro-laico/styles in isolation. Authors a designSet + shortcutSet in the admin, runs the standalone UnoCSS cssHook, and renders the generated stylesheet on a demo page.",
  "license": "MIT",
  "type": "module",
  "exports": {},
  "scripts": {
    "dev": "next dev -p 42150",
    "build": "next build",
    "start": "next start -p 42150",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "payload": "payload",
    "generate:types": "cross-env NODE_OPTIONS=\"--conditions=react-server\" payload generate:types && core-augment-types",
    "generate:importmap": "cross-env NODE_OPTIONS=\"--conditions=react-server\" payload generate:importmap"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "^3.85.1",
    "@payloadcms/live-preview-react": "^3.85.1",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/ui": "^3.85.1",
    "@pro-laico/core": "workspace:*",
    "@pro-laico/styles": "workspace:*",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "payload": "^3.85.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.2",
    "unocss": "^66.7.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "24.x"
  }
}

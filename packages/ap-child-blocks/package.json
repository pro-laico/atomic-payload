{
  "name": "@pro-laico/ap-child-blocks",
  "version": "0.1.0",
  "description": "Atomic Payload child content blocks with a Payload plugin factory. Ships TypeScript source; the app (Next.js) transpiles it.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./default-lexical": {
      "types": "./src/richText/defaultLexical.ts",
      "default": "./src/richText/defaultLexical.ts"
    },
    "./zap": {
      "types": "./src/zap.ts",
      "default": "./src/zap.ts"
    },
    "./useActions/zap": {
      "types": "./src/hooks/useActions/dispatch/zap.ts",
      "default": "./src/hooks/useActions/dispatch/zap.ts"
    },
    "./frontend-components": {
      "types": "./src/frontend-components.ts",
      "default": "./src/frontend-components.ts"
    },
    "./render": {
      "types": "./src/render/index.ts",
      "default": "./src/render/index.ts"
    },
    "./admin/coloredEnd": {
      "types": "./src/components/admin/coloredEnd.tsx",
      "default": "./src/components/admin/coloredEnd.tsx"
    },
    "./admin/actionBlock": {
      "types": "./src/components/admin/actionBlock.tsx",
      "default": "./src/components/admin/actionBlock.tsx"
    },
    "./admin/inputBlock": {
      "types": "./src/components/admin/inputBlock.tsx",
      "default": "./src/components/admin/inputBlock.tsx"
    },
    "./admin/iconSelect": {
      "types": "./src/components/admin/iconSelect.tsx",
      "default": "./src/components/admin/iconSelect.tsx"
    },
    "./admin/atomicRowLabel": {
      "types": "./src/components/admin/AtomicRowLabel.tsx",
      "default": "./src/components/admin/AtomicRowLabel.tsx"
    },
    "./admin/simpleTextRowLabel": {
      "types": "./src/components/admin/SimpleTextRowLabel.tsx",
      "default": "./src/components/admin/SimpleTextRowLabel.tsx"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"process.exit(0)\"",
    "lint": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@mux/mux-video-react": "^0.25.3",
    "@pro-laico/ap-utils": "workspace:*",
    "@pro-laico/ap-types": "workspace:*",
    "@pro-laico/ap-zap": "workspace:*",
    "@pro-laico/ap-apf": "workspace:*",
    "@pro-laico/ap-icons": "workspace:*",
    "@pro-laico/ap-actions": "workspace:*",
    "@pro-laico/ap-forms": "workspace:*",
    "@pro-laico/ap-atomic-hook": "workspace:*",
    "next-themes": "^0.4.6"
  },
  "peerDependencies": {
    "@mux/blurup": ">=1.0.0",
    "@payloadcms/richtext-lexical": ">=3.0.0",
    "@payloadcms/ui": ">=3.0.0",
    "@pro-laico/ap-tracking": "workspace:*",
    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "server-only": ">=0.0.1"
  },
  "peerDependenciesMeta": {
    "@mux/blurup": { "optional": true },
    "@pro-laico/ap-tracking": { "optional": true }
  },
  "devDependencies": {
    "@mux/blurup": "^1.0.2",
    "@payloadcms/richtext-lexical": "^3.79.0",
    "@payloadcms/ui": "^3.79.0",
    "@pro-laico/ap-tracking": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "next": "^16.1.6",
    "payload": "^3.79.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

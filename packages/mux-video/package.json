{
  "name": "@pro-laico/mux-video",
  "version": "0.5.0",
  "description": "Atomic Payload mux-video plugin. Thin wrapper around @oversightstudio/mux-video that adds a local MuxVideo extension collection with Atomic Payload defaults.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pro-laico/atomic-payload.git",
    "directory": "packages/mux-video"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./blocks/videoChild": {
        "types": "./dist/blocks/videoChild/block.d.ts",
        "default": "./dist/blocks/videoChild/block.js"
      },
      "./blocks/videoChild/component": {
        "types": "./dist/blocks/videoChild/component.d.ts",
        "default": "./dist/blocks/videoChild/component.js"
      }
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./blocks/videoChild": {
      "types": "./src/blocks/videoChild/block.ts",
      "default": "./src/blocks/videoChild/block.ts"
    },
    "./blocks/videoChild/component": {
      "types": "./src/blocks/videoChild/component.tsx",
      "default": "./src/blocks/videoChild/component.tsx"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm copyfiles && pnpm build:types && pnpm build:swc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:swc": "swc ./src -d ./dist --config-file ../../.swcrc --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --noCheck",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{scss,css,svg,json,ttf,woff,woff2,eot}\" dist/"
  },
  "dependencies": {
    "@mux/mux-video-react": "^0.31.0",
    "@oversightstudio/mux-video": "^1.4.0",
    "@pro-laico/core": "workspace:*"
  },
  "peerDependencies": {
    "@pro-laico/atomic": ">=0.4.0",
    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@pro-laico/atomic": "workspace:*",
    "@types/react": "^19.2.17",
    "next": "^16.2.9",
    "payload": "^3.85.1",
    "react": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}

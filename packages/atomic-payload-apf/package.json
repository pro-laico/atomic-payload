{
  "name": "@pro-laico/atomic-payload-apf",
  "version": "0.1.0",
  "description": "Atomic Payload Functions (APF). Provides the runAPF runtime, generateAPFFields field generator, field-level hooks, and the admin UI components for marking documents with APF-driven cache invalidation triggers.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./admin/controls": {
      "types": "./dist/components/admin/controls.d.ts",
      "import": "./dist/components/admin/controls.js"
    },
    "./admin/field": {
      "types": "./dist/components/admin/field.d.ts",
      "import": "./dist/components/admin/field.js"
    },
    "./admin/label": {
      "types": "./dist/components/admin/label.d.ts",
      "import": "./dist/components/admin/label.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').cpSync('src/components/admin/index.scss','dist/components/admin/index.scss')\"",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm clean && pnpm build",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pro-laico/atomic-payload-types": "workspace:*"
  },
  "peerDependencies": {
    "@payloadcms/ui": ">=3.0.0",
    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@payloadcms/ui": "^3.79.0",
    "@types/react": "^19.2.14",
    "next": "^16.1.6",
    "payload": "^3.79.0",
    "react": "^19.2.4",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

{
  "name": "@pro-laico/styles",
  "version": "0.1.0",
  "description": "Atomic Payload styles: designSet + shortcutSet collections, token fields, CSS preflight pipeline, UnoCSS processor and processDesignSet pipeline. The single package responsible for all CSS handling (frontend + Payload admin/runtime).",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/types/payload-augment.ts",
      "default": "./src/types/payload-augment.ts"
    },
    "./cssProcessor": {
      "types": "./src/cssProcessor.ts",
      "default": "./src/cssProcessor.ts"
    },
    "./processDesignSet": {
      "types": "./src/processDesignSet/index.ts",
      "default": "./src/processDesignSet/index.ts"
    },
    "./designSet/tabs/colors": {
      "types": "./src/designSet/tabs/colors.ts",
      "default": "./src/designSet/tabs/colors.ts"
    },
    "./designSet/defaults": {
      "types": "./src/designSet/defaults.ts",
      "default": "./src/designSet/defaults.ts"
    },
    "./fields/value": {
      "types": "./src/fields/value.ts",
      "default": "./src/fields/value.ts"
    },
    "./fields/className": {
      "types": "./src/fields/className.ts",
      "default": "./src/fields/className.ts"
    },
    "./globals/storage": {
      "types": "./src/globals/storage.ts",
      "default": "./src/globals/storage.ts"
    },
    "./hooks/cssHook": {
      "types": "./src/hooks/cssHook.ts",
      "default": "./src/hooks/cssHook.ts"
    },
    "./ui/rowLabels/shortcut": {
      "types": "./src/ui/rowLabels/shortcut/index.tsx",
      "default": "./src/ui/rowLabels/shortcut/index.tsx"
    },
    "./ui/rowLabels/color": {
      "types": "./src/ui/rowLabels/color.tsx",
      "default": "./src/ui/rowLabels/color.tsx"
    },
    "./ui/rowLabels/animation": {
      "types": "./src/ui/rowLabels/animation.tsx",
      "default": "./src/ui/rowLabels/animation.tsx"
    },
    "./ui/rowLabels/designToken": {
      "types": "./src/ui/rowLabels/designToken.tsx",
      "default": "./src/ui/rowLabels/designToken.tsx"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"process.exit(0)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pro-laico/zap": "workspace:*",
    "@pro-laico/site": "workspace:*",
    "@pro-laico/core": "workspace:*"
  },
  "peerDependencies": {
    "@payloadcms/ui": ">=3.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0",
    "unocss": ">=66.0.0"
  },
  "peerDependenciesMeta": {
    "unocss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@payloadcms/ui": "^3.79.0",
    "@types/react": "^19.2.14",
    "payload": "^3.79.0",
    "react": "^19.2.4",
    "typescript": "5.8.3",
    "unocss": "^66.6.6"
  },
  "engines": {
    "node": ">=18"
  }
}

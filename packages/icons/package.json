{
  "name": "@pro-laico/icons",
  "version": "0.3.2",
  "description": "Atomic Payload icons package. Provides Icon and IconSet Payload collections, an SVG-optimizing formatSVG hook, SVG extraction helpers, and the AtomicIcon component.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pro-laico/atomic-payload.git",
    "directory": "packages/icons"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/types/payload-augment.d.ts",
        "default": "./dist/types/payload-augment.js"
      },
      "./cache": {
        "types": "./dist/cache/index.d.ts",
        "default": "./dist/cache/index.js"
      },
      "./Icon": {
        "types": "./dist/components/frontend/Icon.d.ts",
        "default": "./dist/components/frontend/Icon.js"
      },
      "./AtomicIcon": {
        "types": "./dist/components/frontend/AtomicIcon.d.ts",
        "default": "./dist/components/frontend/AtomicIcon.js"
      },
      "./admin/iconRowLabel": {
        "types": "./dist/components/admin/iconRowLabel.d.ts",
        "default": "./dist/components/admin/iconRowLabel.js"
      },
      "./admin/iconSelect": {
        "types": "./dist/components/admin/iconSelect.d.ts",
        "default": "./dist/components/admin/iconSelect.js"
      },
      "./admin/iconUsagePanel": {
        "types": "./dist/components/admin/iconUsagePanel.d.ts",
        "default": "./dist/components/admin/iconUsagePanel.js"
      },
      "./scan": {
        "types": "./dist/scan/index.d.ts",
        "default": "./dist/scan/index.js"
      },
      "./blocks/iconChild": {
        "types": "./dist/blocks/iconChild/block.d.ts",
        "default": "./dist/blocks/iconChild/block.js"
      },
      "./blocks/iconChild/component": {
        "types": "./dist/blocks/iconChild/component.d.ts",
        "default": "./dist/blocks/iconChild/component.js"
      },
      "./blocks/svgChild": {
        "types": "./dist/blocks/svgChild/block.d.ts",
        "default": "./dist/blocks/svgChild/block.js"
      },
      "./blocks/svgChild/component": {
        "types": "./dist/blocks/svgChild/component.d.ts",
        "default": "./dist/blocks/svgChild/component.js"
      }
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/types/payload-augment.ts",
      "default": "./src/types/payload-augment.ts"
    },
    "./cache": {
      "types": "./src/cache/index.ts",
      "default": "./src/cache/index.ts"
    },
    "./Icon": {
      "types": "./src/components/frontend/Icon.tsx",
      "default": "./src/components/frontend/Icon.tsx"
    },
    "./AtomicIcon": {
      "types": "./src/components/frontend/AtomicIcon.tsx",
      "default": "./src/components/frontend/AtomicIcon.tsx"
    },
    "./admin/iconRowLabel": {
      "types": "./src/components/admin/iconRowLabel.tsx",
      "default": "./src/components/admin/iconRowLabel.tsx"
    },
    "./admin/iconSelect": {
      "types": "./src/components/admin/iconSelect.tsx",
      "default": "./src/components/admin/iconSelect.tsx"
    },
    "./admin/iconUsagePanel": {
      "types": "./src/components/admin/iconUsagePanel.tsx",
      "default": "./src/components/admin/iconUsagePanel.tsx"
    },
    "./scan": {
      "types": "./src/scan/index.ts",
      "default": "./src/scan/index.ts"
    },
    "./blocks/iconChild": {
      "types": "./src/blocks/iconChild/block.ts",
      "default": "./src/blocks/iconChild/block.ts"
    },
    "./blocks/iconChild/component": {
      "types": "./src/blocks/iconChild/component.tsx",
      "default": "./src/blocks/iconChild/component.tsx"
    },
    "./blocks/svgChild": {
      "types": "./src/blocks/svgChild/block.ts",
      "default": "./src/blocks/svgChild/block.ts"
    },
    "./blocks/svgChild/component": {
      "types": "./src/blocks/svgChild/component.tsx",
      "default": "./src/blocks/svgChild/component.tsx"
    }
  },
  "bin": {
    "atomic-icons-scan": "./dist/scan/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm copyfiles && pnpm build:types && pnpm build:swc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:swc": "swc ./src -d ./dist --config-file ../../.swcrc --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --noCheck",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{scss,css,svg,json,ttf,woff,woff2,eot}\" dist/"
  },
  "dependencies": {
    "@pro-laico/atomic": "workspace:*",
    "@pro-laico/core": "workspace:*"
  },
  "peerDependencies": {
    "@payloadcms/ui": ">=3.0.0",
    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0",
    "server-only": ">=0.0.1",
    "svg-path-bbox": ">=2.0.0",
    "svgo": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "svgo": {
      "optional": true
    },
    "svg-path-bbox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@payloadcms/ui": "^3.85.0",
    "@tools/test-helpers": "workspace:*",
    "@types/react": "^19.2.17",
    "next": "^16.2.7",
    "payload": "^3.85.0",
    "react": "^19.2.7",
    "server-only": "^0.0.1",
    "svg-path-bbox": "^2.1.0",
    "svgo": "^4.0.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}

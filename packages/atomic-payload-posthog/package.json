{
  "name": "@pro-laico/atomic-payload-posthog",
  "version": "0.1.0",
  "description": "Atomic Payload PostHog integration. Provides the posthogProperty collection, the PostHog tab for the tracking global, and a React PostHog provider component.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./provider": {
      "types": "./dist/components/frontend/PostHogProvider.d.ts",
      "import": "./dist/components/frontend/PostHogProvider.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm clean && pnpm build",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pro-laico/atomic-payload-types": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "posthog-js": ">=1.0.0",
    "react": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "posthog-js": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "next": "^16.1.6",
    "payload": "^3.79.0",
    "posthog-js": "^1.360.0",
    "react": "^19.2.4",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

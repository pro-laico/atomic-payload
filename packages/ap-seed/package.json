{
  "name": "@pro-laico/ap-seed",
  "version": "0.1.0",
  "description": "Atomic Payload seed integration. Provides a Payload plugin that wires up a `POST /api/seed` endpoint and a `BeforeDashboard` admin banner with a SEED DATABASE button. Consumers supply the actual seed function.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./admin/beforeDashboard": {
      "types": "./src/components/admin/BeforeDashboard.tsx",
      "default": "./src/components/admin/BeforeDashboard.tsx"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"process.exit(0)\"",
    "lint": "node -e \"process.exit(0)\""
  },
  "peerDependencies": {
    "@payloadcms/ui": ">=3.0.0",
    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@payloadcms/ui": "^3.79.0",
    "@types/react": "^19.2.14",
    "next": "^16.1.6",
    "payload": "^3.79.0",
    "react": "^19.2.4",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

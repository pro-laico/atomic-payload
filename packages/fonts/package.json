{
  "name": "@pro-laico/fonts",
  "version": "0.1.0",
  "description": "Atomic Payload fonts package. Provides the Font upload collection and a CLI script for downloading fonts from the active design set to disk for use with next/font/local.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "atomic-fonts-download": "./dist/scripts/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/types/payload-augment.ts",
      "default": "./src/types/payload-augment.ts"
    },
    "./scripts/downloadFonts": {
      "types": "./dist/scripts/downloadFonts.d.ts",
      "import": "./dist/scripts/downloadFonts.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm clean && pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pro-laico/core": "workspace:*"
  },
  "peerDependencies": {
    "@payloadcms/sdk": ">=3.0.0",
    "dotenv": ">=16.0.0",
    "payload": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@payloadcms/sdk": {
      "optional": true
    },
    "dotenv": {
      "optional": true
    }
  },
  "devDependencies": {
    "@payloadcms/sdk": "^3.79.0",
    "dotenv": "^17.3.1",
    "payload": "^3.79.0",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

{
  "name": "icons-only",
  "version": "0.3.2",
  "description": "Minimal Atomic Payload template demonstrating @pro-laico/icons in isolation. Includes seed data and a demo page that renders the seeded icons.",
  "license": "MIT",
  "type": "module",
  "exports": {},
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "payload": "payload",
    "generate:types": "cross-env NODE_OPTIONS=\"--conditions=react-server\" payload generate:types && core-augment-types",
    "generate:importmap": "cross-env NODE_OPTIONS=\"--conditions=react-server\" payload generate:importmap"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "^3.85.0",
    "@payloadcms/live-preview-react": "^3.85.0",
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/ui": "^3.85.0",
    "@pro-laico/core": "workspace:*",
    "@pro-laico/icons": "workspace:*",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.7",
    "payload": "^3.85.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.34.5",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "24.x"
  }
}

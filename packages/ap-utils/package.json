{
  "name": "@pro-laico/ap-utils",
  "version": "0.1.0",
  "description": "Atomic Payload utilities. Provides revalidateTag server action, collection/global revalidation hooks, a getCached factory, and a Payload plugin for wiring revalidation into any Payload + Next.js project.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./logger": {
      "types": "./dist/utilities/log.d.ts",
      "import": "./dist/utilities/log.js"
    },
    "./cache": {
      "types": "./dist/utilities/cache/index.d.ts",
      "import": "./dist/utilities/cache/index.js"
    },
    "./cache/react": {
      "types": "./dist/utilities/cache/react.d.ts",
      "import": "./dist/utilities/cache/react.js"
    },
    "./cache/auto": {
      "types": "./dist/utilities/cache/auto.d.ts",
      "import": "./dist/utilities/cache/auto.js"
    },
    "./ui/root/siteTriggers": {
      "types": "./dist/ui/root/siteTriggers/index.d.ts",
      "import": "./dist/ui/root/siteTriggers/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').cpSync('src/ui/root/siteTriggers/index.scss','dist/ui/root/siteTriggers/index.scss')\"",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm clean && pnpm build",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pro-laico/ap-atomic-hook": "workspace:*",
    "@pro-laico/ap-types": "workspace:*",
    "@pro-laico/ap-apf": "workspace:*",
    "dayjs": "^1.11.13"
  },
  "peerDependencies": {
    "@payloadcms/ui": ">=3.0.0",
    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0",
    "server-only": ">=0.0.1"
  },
  "devDependencies": {
    "@payloadcms/ui": "^3.79.0",
    "@types/react": "^19.2.14",
    "next": "^16.1.6",
    "payload": "^3.79.0",
    "react": "^19.2.4",
    "server-only": "^0.0.1",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

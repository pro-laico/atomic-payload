{
  "name": "@pro-laico/ap-forms",
  "version": "0.1.0",
  "description": "Atomic Payload form submission blocks (rate limit, sanitation, validation) and server processor. Ships TypeScript source; the app transpiles it.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/types/payload-augment.ts",
      "default": "./src/types/payload-augment.ts"
    },
    "./fields/validationMessage": {
      "types": "./src/fields/validationMessage.ts",
      "default": "./src/fields/validationMessage.ts"
    },
    "./utilities/formatDurationWithTokens": {
      "types": "./src/utilities/formatDurationWithTokens.ts",
      "default": "./src/utilities/formatDurationWithTokens.ts"
    },
    "./utilities/getServerSideURL": {
      "types": "./src/utilities/getServerSideURL.ts",
      "default": "./src/utilities/getServerSideURL.ts"
    },
    "./submitForm/form/zap": {
      "types": "./src/submitForm/form/zap.ts",
      "default": "./src/submitForm/form/zap.ts"
    },
    "./submitForm/input/zap": {
      "types": "./src/submitForm/input/zap.ts",
      "default": "./src/submitForm/input/zap.ts"
    },
    "./submitForm/input/useOn": {
      "types": "./src/submitForm/input/useOn.ts",
      "default": "./src/submitForm/input/useOn.ts"
    },
    "./submitForm/serverFunction": {
      "types": "./src/submitForm/serverFunction.ts",
      "default": "./src/submitForm/serverFunction.ts"
    },
    "./submitForm/formProcessor": {
      "types": "./src/submitForm/formProcessor.ts",
      "default": "./src/submitForm/formProcessor.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "lint": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@pro-laico/ap-actions": "workspace:*",
    "@pro-laico/ap-zap": "workspace:*",
    "dayjs": "^1.11.19",
    "@pro-laico/ap-core": "workspace:*"
  },
  "peerDependencies": {
    "atomic-payload": "workspace:*",
    "next": ">=15.0.0",
    "payload": ">=3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}

{
  "name": "@pro-laico/atomic-payload-images",
  "version": "0.1.0",
  "description": "Atomic Payload images package. Provides Images + Favicons Payload upload collections, a FaviconField helper, and a plugin factory that optionally wires the @oversightstudio/blur-data-urls plugin.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm clean && pnpm build",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pro-laico/atomic-payload-types": "workspace:*",
    "@pro-laico/ap-utils": "workspace:*",
    "@pro-laico/atomic-payload-apf": "workspace:*"
  },
  "peerDependencies": {
    "@oversightstudio/blur-data-urls": ">=1.0.0",
    "payload": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@oversightstudio/blur-data-urls": { "optional": true }
  },
  "devDependencies": {
    "@oversightstudio/blur-data-urls": "^1.0.4",
    "payload": "^3.79.0",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

{
  "name": "@pro-laico/ap-zap",
  "version": "0.1.0",
  "description": "Zod with Atomic Payload extensions - a registry-aware schema layer used across the Atomic Payload packages and templates. Re-exports zod and adds the `z.ap` helper class for registering and retrieving schemas typed against AtomicRegistry.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/types/payload-augment.ts",
      "default": "./src/types/payload-augment.ts"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm clean && pnpm build",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pro-laico/ap-types": "workspace:*",
    "server-only": "^0.0.1",
    "traverse": "^0.6.11",
    "zod": "4.1.11"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/traverse": "^0.6.37",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

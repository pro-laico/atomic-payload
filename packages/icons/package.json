{
  "name": "@pro-laico/icons",
  "version": "0.1.0",
  "description": "Atomic Payload icons package. Provides Icon and IconSet Payload collections, an SVG-optimizing formatSVG hook, SVG extraction helpers, and the AtomicIcon component.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/types/payload-augment.ts",
      "default": "./src/types/payload-augment.ts"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./admin/iconRowLabel": {
      "types": "./dist/components/admin/iconRowLabel.d.ts",
      "import": "./dist/components/admin/iconRowLabel.js"
    },
    "./admin/iconSelect": {
      "types": "./dist/components/admin/iconSelect.d.ts",
      "import": "./dist/components/admin/iconSelect.js"
    },
    "./iconSet/defaults": {
      "types": "./dist/iconSet/defaults.d.ts",
      "import": "./dist/iconSet/defaults.js"
    },
    "./blocks/iconChild": {
      "types": "./src/blocks/iconChild/block.ts",
      "default": "./src/blocks/iconChild/block.ts"
    },
    "./blocks/iconChild/component": {
      "types": "./src/blocks/iconChild/component.tsx",
      "default": "./src/blocks/iconChild/component.tsx"
    },
    "./blocks/svgChild": {
      "types": "./src/blocks/svgChild/block.ts",
      "default": "./src/blocks/svgChild/block.ts"
    },
    "./blocks/svgChild/component": {
      "types": "./src/blocks/svgChild/component.tsx",
      "default": "./src/blocks/svgChild/component.tsx"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm clean && pnpm build",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pro-laico/core": "workspace:*",
    "@pro-laico/atomic": "workspace:*"
  },
  "peerDependencies": {
    "@payloadcms/ui": ">=3.0.0",
    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0",
    "svg-path-bbox": ">=2.0.0",
    "svgo": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "svgo": {
      "optional": true
    },
    "svg-path-bbox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@payloadcms/ui": "^3.79.0",
    "@types/react": "^19.2.14",
    "next": "^16.1.6",
    "payload": "^3.79.0",
    "react": "^19.2.4",
    "svg-path-bbox": "^2.1.0",
    "svgo": "^3.3.3",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

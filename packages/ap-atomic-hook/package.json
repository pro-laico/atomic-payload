{
  "name": "@pro-laico/ap-atomic-hook",
  "version": "0.1.0",
  "description": "Atomic Payload atomicHook implementation (beforeChange orchestration, CSS/design-set processing, zustand atomic store) and a plugin factory that attaches the hook to listed collections.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/types/payload-augment.ts",
      "default": "./src/types/payload-augment.ts"
    },
    "./light": {
      "types": "./dist/light.d.ts",
      "import": "./dist/light.js"
    },
    "./client": {
      "types": "./dist/frontEnd/atomicStore/index.d.ts",
      "import": "./dist/frontEnd/atomicStore/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm clean && pnpm build",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pro-laico/ap-actions": "workspace:*",
    "@pro-laico/ap-design-sets": "workspace:*",
    "@pro-laico/ap-zap": "workspace:*",
    "traverse": "^0.6.11",
    "@pro-laico/ap-forms": "workspace:*",
    "@pro-laico/ap-site": "workspace:*",
    "@pro-laico/ap-core": "workspace:*"
  },
  "peerDependencies": {
    "payload": ">=3.0.0",
    "react": ">=19.0.0",
    "unocss": ">=66.0.0",
    "zustand": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "unocss": {
      "optional": true
    },
    "zustand": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/traverse": "^0.6.37",
    "payload": "^3.79.0",
    "react": "^19.2.4",
    "typescript": "5.8.3",
    "unocss": "^66.6.6",
    "zustand": "^5.0.11"
  },
  "engines": {
    "node": ">=18"
  }
}

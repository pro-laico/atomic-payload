{
  "name": "@pro-laico/ap-richtext",
  "version": "0.1.0",
  "description": "Atomic Payload rich-text package. Provides the RichTextChild block, a default Lexical editor preset, and a JSX renderer for serialized Lexical content.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./default-lexical": {
      "types": "./src/blocks/richText/defaultLexical.ts",
      "default": "./src/blocks/richText/defaultLexical.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"process.exit(0)\"",
    "lint": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@pro-laico/ap-core": "workspace:*",
    "@pro-laico/children": "workspace:*"
  },
  "peerDependencies": {
    "@payloadcms/richtext-lexical": ">=3.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@payloadcms/richtext-lexical": "^3.79.0",
    "@types/react": "^19.2.14",
    "payload": "^3.79.0",
    "react": "^19.2.4",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

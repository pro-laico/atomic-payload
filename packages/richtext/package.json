{
  "name": "@pro-laico/richtext",
  "version": "0.5.0",
  "description": "Atomic Payload rich-text package. Provides the RichTextChild block, a default Lexical editor preset, and a JSX renderer for serialized Lexical content.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pro-laico/atomic-payload.git",
    "directory": "packages/richtext"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./default-lexical": {
        "types": "./dist/blocks/richText/defaultLexical.d.ts",
        "default": "./dist/blocks/richText/defaultLexical.js"
      }
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./default-lexical": {
      "types": "./src/blocks/richText/defaultLexical.ts",
      "default": "./src/blocks/richText/defaultLexical.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm copyfiles && pnpm build:types && pnpm build:swc",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:swc": "swc ./src -d ./dist --config-file ../../.swcrc --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --noCheck",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{scss,css,svg,json,ttf,woff,woff2,eot}\" dist/",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@pro-laico/core": "workspace:*"
  },
  "peerDependencies": {
    "@payloadcms/richtext-lexical": ">=3.0.0",
    "@pro-laico/atomic": ">=0.4.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@payloadcms/richtext-lexical": "^3.85.1",
    "@pro-laico/atomic": "workspace:*",
    "@types/react": "^19.2.17",
    "payload": "^3.85.1",
    "react": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}

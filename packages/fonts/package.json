{
  "name": "@pro-laico/fonts",
  "version": "0.4.2",
  "description": "Atomic Payload fonts package. Provides the Font upload collection and a CLI script for downloading fonts from the active design set to disk for use with next/font/local.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pro-laico/atomic-payload.git",
    "directory": "packages/fonts"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/types/payload-augment.d.ts",
        "default": "./dist/types/payload-augment.js"
      },
      "./admin/fontUploader": {
        "types": "./dist/components/admin/fontUploader.d.ts",
        "default": "./dist/components/admin/fontUploader.js"
      },
      "./scripts/downloadFonts": {
        "types": "./dist/scripts/downloadFonts.d.ts",
        "default": "./dist/scripts/downloadFonts.js"
      }
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "atomic-fonts-download": "./dist/scripts/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/types/payload-augment.ts",
      "default": "./src/types/payload-augment.ts"
    },
    "./admin/fontUploader": {
      "types": "./src/components/admin/fontUploader.tsx",
      "default": "./src/components/admin/fontUploader.tsx"
    },
    "./scripts/downloadFonts": {
      "types": "./src/scripts/downloadFonts.ts",
      "default": "./src/scripts/downloadFonts.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm copyfiles && pnpm build:types && pnpm build:swc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:swc": "swc ./src -d ./dist --config-file ../../.swcrc --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --noCheck",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{scss,css,svg,json,ttf,woff,woff2,eot}\" dist/"
  },
  "dependencies": {
    "@pro-laico/core": "workspace:*",
    "dotenv": "^17.4.2",
    "fontkit": "^2.0.0",
    "subset-font": "^2.0.0"
  },
  "peerDependencies": {
    "@payloadcms/ui": ">=3.0.0",
    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "dotenv": {
      "optional": true
    }
  },
  "devDependencies": {
    "@payloadcms/ui": "^3.85.0",
    "@tools/test-helpers": "workspace:*",
    "@types/fontkit": "^2.0.0",
    "@types/react": "^19.2.17",
    "@types/subset-font": "^2.0.0",
    "next": "^16.2.7",
    "payload": "^3.85.0",
    "react": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}

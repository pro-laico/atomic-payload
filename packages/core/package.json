{
  "name": "@pro-laico/core",
  "version": "0.1.0",
  "description": "Atomic Payload core: kernel types (PayloadAugment / Get<>), APF (Atomic Payload Functions), shared utilities, cache helpers, revalidation plugin, JSON-schema plugin, and admin / frontend UI primitives. Replaces the older ap-types + ap-apf + ap-utils trio.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./kernel": {
        "types": "./dist/kernel.d.ts",
        "default": "./dist/kernel.js"
      },
      "./logger": {
        "types": "./dist/utilities/log.d.ts",
        "default": "./dist/utilities/log.js"
      },
      "./cache": {
        "types": "./dist/utilities/cache/index.d.ts",
        "default": "./dist/utilities/cache/index.js"
      },
      "./cache/react": {
        "types": "./dist/utilities/cache/react.d.ts",
        "default": "./dist/utilities/cache/react.js"
      },
      "./cache/auto": {
        "types": "./dist/utilities/cache/auto.d.ts",
        "default": "./dist/utilities/cache/auto.js"
      },
      "./payload": {
        "types": "./dist/utilities/getPayloadInstance.d.ts",
        "default": "./dist/utilities/getPayloadInstance.js"
      },
      "./ui/root/siteTriggers": {
        "types": "./dist/ui/root/siteTriggers/index.d.ts",
        "default": "./dist/ui/root/siteTriggers/index.js"
      },
      "./ui/fields/slug": {
        "types": "./dist/ui/fields/slug/index.d.ts",
        "default": "./dist/ui/fields/slug/index.js"
      },
      "./components/frontend/Toaster": {
        "types": "./dist/components/frontend/Toaster.d.ts",
        "default": "./dist/components/frontend/Toaster.js"
      },
      "./components/frontend/LivePreviewListener": {
        "types": "./dist/components/frontend/LivePreviewListener.d.ts",
        "default": "./dist/components/frontend/LivePreviewListener.js"
      },
      "./next/preview": {
        "types": "./dist/next/previewRouteHandler.d.ts",
        "default": "./dist/next/previewRouteHandler.js"
      },
      "./next/exit-preview": {
        "types": "./dist/next/exitPreviewRouteHandler.d.ts",
        "default": "./dist/next/exitPreviewRouteHandler.js"
      },
      "./auth/getMeUser": {
        "types": "./dist/utilities/getMeUser.d.ts",
        "default": "./dist/utilities/getMeUser.js"
      },
      "./admin/controls": {
        "types": "./dist/apf/components/admin/controls.d.ts",
        "default": "./dist/apf/components/admin/controls.js"
      },
      "./admin/field": {
        "types": "./dist/apf/components/admin/field.d.ts",
        "default": "./dist/apf/components/admin/field.js"
      },
      "./admin/label": {
        "types": "./dist/apf/components/admin/label.d.ts",
        "default": "./dist/apf/components/admin/label.js"
      },
      "./src": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./config": {
        "types": "./dist/config/index.d.ts",
        "default": "./dist/config/index.js"
      }
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "core-augment-types": "./scripts/appendPayloadAugment.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./kernel": {
      "types": "./src/kernel.ts",
      "default": "./src/kernel.ts"
    },
    "./logger": {
      "types": "./src/utilities/log.ts",
      "default": "./src/utilities/log.ts"
    },
    "./cache": {
      "types": "./src/utilities/cache/index.ts",
      "default": "./src/utilities/cache/index.ts"
    },
    "./cache/react": {
      "types": "./src/utilities/cache/react.ts",
      "default": "./src/utilities/cache/react.ts"
    },
    "./cache/auto": {
      "types": "./src/utilities/cache/auto.ts",
      "default": "./src/utilities/cache/auto.ts"
    },
    "./payload": {
      "types": "./src/utilities/getPayloadInstance.ts",
      "default": "./src/utilities/getPayloadInstance.ts"
    },
    "./ui/root/siteTriggers": {
      "types": "./src/ui/root/siteTriggers/index.tsx",
      "default": "./src/ui/root/siteTriggers/index.tsx"
    },
    "./ui/fields/slug": {
      "types": "./src/ui/fields/slug/index.tsx",
      "default": "./src/ui/fields/slug/index.tsx"
    },
    "./components/frontend/Toaster": {
      "types": "./src/components/frontend/Toaster.tsx",
      "default": "./src/components/frontend/Toaster.tsx"
    },
    "./components/frontend/LivePreviewListener": {
      "types": "./src/components/frontend/LivePreviewListener.tsx",
      "default": "./src/components/frontend/LivePreviewListener.tsx"
    },
    "./next/preview": {
      "types": "./src/next/previewRouteHandler.ts",
      "default": "./src/next/previewRouteHandler.ts"
    },
    "./next/exit-preview": {
      "types": "./src/next/exitPreviewRouteHandler.ts",
      "default": "./src/next/exitPreviewRouteHandler.ts"
    },
    "./auth/getMeUser": {
      "types": "./src/utilities/getMeUser.ts",
      "default": "./src/utilities/getMeUser.ts"
    },
    "./admin/controls": {
      "types": "./src/apf/components/admin/controls.tsx",
      "default": "./src/apf/components/admin/controls.tsx"
    },
    "./admin/field": {
      "types": "./src/apf/components/admin/field.tsx",
      "default": "./src/apf/components/admin/field.tsx"
    },
    "./admin/label": {
      "types": "./src/apf/components/admin/label.tsx",
      "default": "./src/apf/components/admin/label.tsx"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "default": "./src/config/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm copyfiles && pnpm build:types && pnpm build:swc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:swc": "swc ./src -d ./dist --config-file ../../.swcrc --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --noCheck",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{scss,css,svg,json}\" dist/"
  },
  "dependencies": {
    "@types/json-schema": "^7.0.15",
    "dayjs": "^1.11.13",
    "traverse": "^0.6.11"
  },
  "peerDependencies": {
    "@base-ui-components/react": ">=1.0.0-rc.0",
    "@payloadcms/live-preview-react": ">=3.0.0",
    "@payloadcms/ui": ">=3.0.0",
    "@pro-laico/atomic": ">=0.1.0",
    "@pro-laico/images": ">=0.1.0",
    "@pro-laico/site": ">=0.1.0",
    "@pro-laico/styles": ">=0.1.0",
    "@pro-laico/tracking": ">=0.1.0",
    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0",
    "server-only": ">=0.0.1"
  },
  "peerDependenciesMeta": {
    "@pro-laico/atomic": {
      "optional": true
    },
    "@pro-laico/images": {
      "optional": true
    },
    "@pro-laico/site": {
      "optional": true
    },
    "@pro-laico/styles": {
      "optional": true
    },
    "@pro-laico/tracking": {
      "optional": true
    }
  },
  "devDependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@payloadcms/live-preview-react": "^3.79.0",
    "@payloadcms/translations": "^3.79.0",
    "@payloadcms/ui": "^3.79.0",
    "@pro-laico/atomic": "workspace:*",
    "@pro-laico/images": "workspace:*",
    "@pro-laico/site": "workspace:*",
    "@pro-laico/styles": "workspace:*",
    "@pro-laico/tracking": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/traverse": "^0.6.37",
    "next": "^16.1.6",
    "payload": "^3.79.0",
    "react": "^19.2.4",
    "server-only": "^0.0.1",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

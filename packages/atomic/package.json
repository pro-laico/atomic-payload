    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "server-only": ">=0.0.1",
    "unocss": ">=66.0.0",
    "zustand": ">=5.0.0"

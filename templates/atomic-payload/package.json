{
  "name": "atomic-payload",
  "version": "0.4.2",
  "description": "The Payload CMS Starter Where All You Need To Know Is Tailwind.",
  "license": "MIT",
  "type": "module",
  "exports": {},
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "payload": "payload",
    "start": "next start -p 42100",
    "build": "next build",
    "dev": "next dev -p 42100",
    "prebuild": "pnpm generate:fonts && pnpm generate:icons",
    "generate:fonts": "pnpm exec tsx node_modules/@pro-laico/fonts/src/scripts/cli.ts",
    "generate:icons": "pnpm exec tsx node_modules/@pro-laico/icons/src/scan/cli.ts src",
    "generate:types": "cross-env NODE_OPTIONS=\"--conditions=react-server\" payload generate:types && core-augment-types",
    "generate:importmap": "cross-env NODE_OPTIONS=\"--conditions=react-server\" payload generate:importmap"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@mux/blurup": "^1.0.2",
    "@mux/mux-video-react": "^0.31.0",
    "@next/bundle-analyzer": "^16.2.9",
    "@next/third-parties": "^16.2.9",
    "@oversightstudio/mux-video": "^1.4.0",
    "@payloadcms/db-mongodb": "^3.85.1",
    "@payloadcms/email-resend": "^3.85.1",
    "@payloadcms/live-preview-react": "^3.85.1",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/plugin-form-builder": "^3.85.1",
    "@payloadcms/plugin-nested-docs": "^3.85.1",
    "@payloadcms/richtext-lexical": "^3.85.1",
    "@payloadcms/sdk": "^3.85.1",
    "@payloadcms/storage-vercel-blob": "^3.85.1",
    "@payloadcms/ui": "^3.85.1",
    "@pro-laico/atomic": "workspace:*",
    "@pro-laico/core": "workspace:*",
    "@pro-laico/fonts": "workspace:*",
    "@pro-laico/icons": "workspace:*",
    "@pro-laico/images": "workspace:*",
    "@pro-laico/mux-video": "workspace:*",
    "@pro-laico/richtext": "workspace:*",
    "@pro-laico/seed": "workspace:*",
    "@pro-laico/site": "workspace:*",
    "@pro-laico/styles": "workspace:*",
    "@pro-laico/tracking": "workspace:*",
    "@pro-laico/zap": "workspace:*",
    "@vercel/analytics": "^2.0.1",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "payload": "^3.85.1",
    "posthog-js": "^1.393.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "sharp": "^0.35.2",
    "svg-path-bbox": "^2.1.0",
    "svgo": "^4.0.1",
    "traverse": "^0.6.11",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/traverse": "^0.6.37",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2"
  },
  "engines": {
    "node": "24.x"
  }
}

{
  "name": "@pro-laico/atomic-payload-design-sets",
  "version": "0.1.0",
  "description": "Atomic Payload designSet collection (tabs, token fields, CSS preflight pipeline inputs) and designSetsPlugin. Ships TypeScript source; the app transpiles it.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./designSet/tabs/colors": {
      "types": "./src/designSet/tabs/colors.ts",
      "default": "./src/designSet/tabs/colors.ts"
    },
    "./designSet/defaults": {
      "types": "./src/designSet/defaults.ts",
      "default": "./src/designSet/defaults.ts"
    },
    "./fields/value": {
      "types": "./src/fields/value.ts",
      "default": "./src/fields/value.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"process.exit(0)\"",
    "lint": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@pro-laico/atomic-payload-apf": "workspace:*",
    "@pro-laico/ap-utils": "workspace:*",
    "@pro-laico/atomic-payload-types": "workspace:*",
    "@pro-laico/atomic-payload-zap": "workspace:*"
  },
  "peerDependencies": {
    "payload": ">=3.0.0"
  },
  "devDependencies": {
    "payload": "^3.79.0",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

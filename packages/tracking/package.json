{
  "name": "@pro-laico/tracking",
  "version": "0.3.0",
  "description": "Atomic Payload tracking integration. Home for all tracking-related functionality (Tracking global, PostHog autocapture provider, Google Tag Manager tab + provider, Vercel Analytics provider, composite TrackingProvider) plugged into atomic-payload.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pro-laico/atomic-payload.git",
    "directory": "packages/tracking"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/types/payload-augment.d.ts",
        "default": "./dist/types/payload-augment.js"
      },
      "./cache": {
        "types": "./dist/cache/index.d.ts",
        "default": "./dist/cache/index.js"
      },
      "./provider": {
        "types": "./dist/components/frontend/index.d.ts",
        "default": "./dist/components/frontend/index.js"
      }
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/types/payload-augment.ts",
      "default": "./src/types/payload-augment.ts"
    },
    "./cache": {
      "types": "./src/cache/index.ts",
      "default": "./src/cache/index.ts"
    },
    "./provider": {
      "types": "./src/components/frontend/index.ts",
      "default": "./src/components/frontend/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm copyfiles && pnpm build:types && pnpm build:swc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:swc": "swc ./src -d ./dist --config-file ../../.swcrc --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --noCheck",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{scss,css,svg,json,ttf,woff,woff2,eot}\" dist/"
  },
  "dependencies": {
    "@pro-laico/core": "workspace:*"
  },
  "peerDependencies": {
    "@next/third-parties": ">=15.0.0",
    "@vercel/analytics": ">=1.0.0",
    "next": ">=15.0.0",
    "payload": ">=3.0.0",
    "posthog-js": ">=1.0.0",
    "react": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "@next/third-parties": {
      "optional": true
    },
    "@vercel/analytics": {
      "optional": true
    },
    "posthog-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@next/third-parties": "^16.1.6",
    "@types/react": "^19.2.14",
    "@vercel/analytics": "^1.6.1",
    "next": "^16.1.6",
    "payload": "^3.79.0",
    "posthog-js": "^1.360.0",
    "react": "^19.2.4",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}

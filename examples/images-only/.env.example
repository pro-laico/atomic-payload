PAYLOAD_SECRET=replace-me-with-a-long-random-string

# The deployment origin. The on-demand transform endpoint self-fetches Payload's
# own static file route to read the source image, so this must point at where the
# app is actually served (it falls back to http://localhost:3000 for local dev).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional. Defaults to `file:./images-only.db` (local SQLite). Swap to any
# Payload-supported adapter by editing src/payload.config.ts and setting the
# matching connection string here.
# DATABASE_URI=file:./images-only.db

# Mongo DB connection string
MONGODB_URI=
# Vercel Blob Read Write Secret
BLOB_READ_WRITE_TOKEN=

# Used to encrypt JWT tokens
PAYLOAD_SECRET=
# Used to validate preview requests
PREVIEW_SECRET=

# Used to configure CORS, format links, and more. No trailing slash. In
# production set this to your deployed URL.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Where `generate:fonts` downloads next/font/local fonts from (authenticating
# with PAYLOAD_SECRET). Set to your running instance — localhost in dev, your
# deployed URL in production.
FONT_DOWNLOAD_URL=http://localhost:3000

#Vercel Deploy Webhook. Used to rebuild the website from admin ui.
VERCEL_DEPLOY_WEBHOOK_URL=

#Mux Secrets. For mux video block component.
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SIGNING_SECRET=

RESEND_API_KEY=

#Set to true to use bundle analyzer
ANALYZE=false
#Manage whether or not to log cached getters and more. (true / false)
LOGS=false